# ---- Terraform ----
# state は必ず除外（ローカル state に機密が含まれるため）
*.tfstate
*.tfstate.*
*.tfstate.backup
# 本番の backend 設定（バケット名等が入るため）
infra/terraform/envs/prod/backend.config
# プロバイダー・モジュールのキャッシュ
.terraform/
.terraform.lock.hcl
# plan 出力（任意だが含めると差分が残る）
*.tfplan

# ---- 環境変数・シークレット ----
.env
.env.*
!.env.example
*.pem
*.key

# ---- OS・エディタ ----
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---- ログ・一時ファイル ----
*.log
tmp/
temp/
.cache/

# ---- フロント（Deno / ビルド） ----
frontend/dist/
frontend/.vinxi/

# ---- バックエンド（Go） ----
backend/api
backend/*.exe
backend/vendor/

# ---- その他 ----
*.zip
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
